# ==================================================================================================
# Terrane — environment file.
# Copy this file to `.env` and fill in every #REPLACE_ME#. NEVER commit your real .env.
# Style mirrors Dify's .env.example: sectioned, every variable documented, secure-by-default.
# The backend FAILS CLOSED in production if the KEK (TERRANE_KEK) is missing or invalid.
# ==================================================================================================

# ------------------------------
# Image / Registry
# ------------------------------

# Registry path (host + namespace) that holds the six Terrane images
# (terrane-server / terrane-admin-server / terrane-gateway / terrane-web / terrane-admin-web /
# terrane-postgres). Point this at your private Harbor / Aliyun ACR mirror for on-prem.
# Example: harbor.intra.example.com/terrane
REGISTRY=crpi-ew8juv9423tvogc4.cn-hongkong.personal.cr.aliyuncs.com/navtra-mirror

# Image tag pulled for every component. Bump this to upgrade the whole stack.
# Example: v1.0.0
TERRANE_TAG=v1.0.0

# ------------------------------
# Common
# ------------------------------

# IANA timezone for all containers. Affects timestamps in logs and the database.
# Example: Asia/Shanghai, UTC
TZ=Asia/Shanghai

# Backend log level. One of: DEBUG | INFO | WARNING | ERROR.
# Use INFO in production; DEBUG only for troubleshooting (verbose).
LOG_LEVEL=INFO

# Session-cookie Secure flag.
# Keep FALSE for a plain-HTTP trial (the default below) — otherwise the browser drops the login
# cookie over HTTP and you can never stay signed in.
# Set TRUE once you serve the console over HTTPS (behind an Nginx/Caddy TLS reverse proxy).
SESSION_COOKIE_SECURE=false

# Host port published for the FRONT app (knowledge base / Chat / memory / studio).
# Browser uses https://<host> on 443 when you terminate TLS at a reverse proxy.
# Example: 80, 8080
WEB_PORT=80

# Host port published for the ADMIN console (activation / setup wizard / model channels / members).
# Example: 8081
ADMIN_WEB_PORT=8081

# Public access URL used to build the links inside verification / password-reset emails.
# Leave EMPTY (default) and Terrane auto-follows the exact address each user visited (your IP or
# domain) — email links track your deployment automatically, nothing to configure.
# Set it ONLY to pin a fixed public URL, e.g. when serving over HTTPS behind a reverse proxy.
# Example: http://118.89.84.188:8090, https://kb.example.com
FRONTEND_BASE_URL=

# ------------------------------
# Field-encryption Master Key (KEK)
# ------------------------------

# TERRANE_KEK — the master key that encrypts sensitive fields at rest:
# SMTP password, 2FA secrets, stored credentials.
# Generate a strong key with: openssl rand -base64 32
# SECURITY: back this up together with your database. LOSING IT makes all existing ciphertext
# permanently unrecoverable, and the backend fails closed (refuses to start) when it is empty.
TERRANE_KEK=#REPLACE_ME#

# ------------------------------
# License (Forge)
# ------------------------------

# Online-activation edge URL (your Forge license authority). The admin console calls this to activate
# the deployment.
# Leave EMPTY for offline-only (air-gapped) activation, where an operator pastes a signed .forge
# license blob in the admin console instead.
# Example: http://118.89.84.188:8081, https://edge.forge.example.com
TERRANE_FORGE_EDGE_URL=http://118.89.84.188:8081

# Deployment identity shared by all components (server / admin-server / gateway). REQUIRED so that
# online activation done in the admin console also unlocks the front app — without it, each container
# uses its own random machine-id and you'll see "后台已激活、前台仍未激活".
# Generate ONCE with: openssl rand -hex 16    (set the same value for the whole deployment; do NOT
# change it after activating, or you must re-activate).
FORGE_DEPLOYMENT_UID=#REPLACE_ME#

# ------------------------------
# Database — PostgreSQL 18 + Apache AGE + pgvector
# ------------------------------
# These extensions are REQUIRED: AGE powers the knowledge graph, pgvector powers semantic retrieval.
# DEFAULT: the bundled `postgres` service (the terrane-postgres image) ships both and starts with
# `docker compose up -d` — keep DATABASE_HOST=postgres below.
# To use an EXTERNAL / managed / 信创 PostgreSQL-compatible DB instead, set DATABASE_HOST to its host
# (it MUST provide the `age` and `vector` extensions) and comment out the `postgres` service in
# docker-compose.yaml.
# One instance hosts two logical databases — terrane_main (platform) + terrane_admin (operators) —
# created automatically on first init by ./init/01-databases.sql.

# Database host. Keep `postgres` for the bundled DB (default). For an external DB set it to that host,
# e.g. pg.internal.example.com
DATABASE_HOST=postgres

# Database port.
# Example: 5432
DATABASE_PORT=5432

# Full-privilege business DB account used by both control planes.
DATABASE_USERNAME=terrane_app

# Password for the DB account.
# Generate: openssl rand -base64 24
DATABASE_PASSWORD=#REPLACE_ME#

# TLS mode for the database connection.
# One of: disable | prefer | require | verify-ca | verify-full.
# `disable` is fine for the in-cluster bundled DB; use `require`+ for an external DB over the network.
DATABASE_SSL_MODE=disable

# ------------------------------
# Cache — Redis
# ------------------------------
# DEFAULT: the bundled `redis` service starts with `docker compose up -d` — keep CACHE_HOST=redis.
# To use an EXTERNAL Redis, set CACHE_HOST to its host and comment out the `redis` service.

# Redis host. Keep `redis` for the bundled cache (default); for an external Redis set it to that host,
# e.g. redis.internal.example.com
CACHE_HOST=redis

# Redis port.
# Example: 6379
CACHE_PORT=6379

# Redis password (required by the bundled Redis below).
# Generate: openssl rand -base64 24
CACHE_PASSWORD=#REPLACE_ME#

# ------------------------------
# Private CA (optional)
# ------------------------------

# Trust a self-signed / private-CA https certificate on your DB / mail / object-storage endpoints
# (common on 信创 enterprise intranets). Set this to the HOST path of your CA bundle (PEM); it is
# mounted into the backend containers and exported as SSL_CERT_FILE / REQUESTS_CA_BUNDLE /
# CURL_CA_BUNDLE.
# Leave EMPTY to use only the system CAs.
# Example: /etc/terrane/ca/intranet-root.pem
TERRANE_CA_FILE=
