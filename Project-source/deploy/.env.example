# ===== Terrane 部署配置(复制为 .env 填写)=====
# 数据库(出厂内置 PG,密码请改)
POSTGRES_PASSWORD=change-me-strong-pg-pass
# 缓存
REDIS_PASSWORD=change-me-strong-redis-pass
# KEK 字段加密主密钥(L5:SMTP/2FA/凭据)。生产必设,丢失则无法解密既有密文。
TERRANE_KEK=change-me-32+chars-random-secret
# License 门控总开关:开源版默认 false → 全程放行(表现为始终已激活,前端隐藏激活/徽章)。
# 商业化部署设 true 即恢复 Forge 验签门控;仅 true 时下方 TERRANE_FORGE_EDGE_URL 等才生效(代码完整保留,可逆)。
LICENSE_REQUIRED=false
# License(出厂内置签名公钥;在线激活边缘地址)——仅 LICENSE_REQUIRED=true 时生效
TERRANE_FORGE_EDGE_URL=http://118.89.84.188:8081
# Cookie 安全(HTTPS 部署设 true)
SESSION_COOKIE_SECURE=true
